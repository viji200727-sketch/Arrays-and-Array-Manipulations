import java.util.Scanner;
class NoVowels {
    public static void main(String[] args) {
        Scanner get = new Scanner(System.in);
        
        // Getting the string
        System.out.print("Enter a String: ");
        String string = get.nextLine();
        String str = string.toLowerCase();
        
        // Calculating the vowel count
        char[] vowel = {'a','e','i','o','u'};
        String rep = str;
        for (char c:vowel)
            for (int i=0;i<str.length();i++)
                if (Character.toString(c).equals(Character.toString(str.charAt(i))))
                    rep = rep.replace(Character.toString(str.charAt(i)),"");
        
        // Displaying the string after the vowel(s) is removed 
        System.out.println("The string after removing the vowels is: "+rep);
    }
}
