import java.util.Scanner;
class LarSmall {
    public static void main(String[] args) {
        Scanner get = new Scanner(System.in);
        
        // Initialization of array
        System.out.print("Enter array size: ");
        int array_size = get.nextInt();
        int[] array = new int[array_size];
        
        // Inputting array elements
        System.out.print("Enter array elements: ");
        for(int i=0;i<array_size;i++){
            array[i]=get.nextInt();
        }
        
        // Displaying the array
        System.out.print("Array Elements are : ");
        for (int i = 0; i<array_size; i++)
            System.out.print(array[i] + " ");
        System.out.println();
        
        // Calculating largest and smallest element in the array
        int largest = array[0];
        int smallest = array[0];
        for (int i = 0; i<array_size; i++) 
        {
            if (array[i]>largest) largest = array[i];
            if (array[i]<smallest) smallest = array[i]; 
        }
            
        // Calculating second largest and second smallest element in the array
        int sec_largest = -99999;
        int sec_smallest = 99999;
        for (int i = 0; i<array_size; i++) 
        {
            if (array[i]>sec_largest && array[i]!=largest) sec_largest = array[i];
            if (array[i]<sec_smallest && array[i]!=smallest) sec_smallest = array[i];
        }
            
        // Displaying the result
        System.out.println("Largest element: "+largest);
        System.out.println("Second largest element: "+sec_largest);
        System.out.println("Smallest element: "+smallest);
        System.out.println("Second smallest element: "+sec_smallest);
    }
}
